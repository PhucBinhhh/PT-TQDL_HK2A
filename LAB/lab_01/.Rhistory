set1 <- data.frame(IdClient = c(1:6 , 8 ) , Product = c(rep("Thit kho",4), rep("Ca kho", 3 ))
set2 <- data.frame(IdClient = c(1,2,5,9) , Region = c(rep("TP. HCM ",3), "Dong Nai")
