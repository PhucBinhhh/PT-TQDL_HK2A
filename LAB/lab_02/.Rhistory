mean_score <- function(scores) {
if (!is.numeric(scores)) {
return("Input phải là vector số")
}
scores <- scores[!is.na(scores)]
if (length(scores) == 0) {
return("Không có điểm hợp lệ")
}
if (any(scores < 0 | scores > 10)) {
return("Điểm phải nằm trong khoảng 0 đến 10")
}
return(mean(scores))
}
mean_score(c(9,2,4))
mean_score(c(2,4))
mean_score(c(11,4))
mean_score(c(NA,4))
mean_score(c(NA,4))
# 1. Viết function tính toán tổng quan
# Input: vector số
# Output: list(mean, median, sd, min, max, range)
summary_stats <- function(x) {
if (!is.numeric(x)) {
return("Input phải là vector số")
}
x <- x[!is.na(x)]
if (length(x) == 0) {
return("Không có dữ liệu hợp lệ")
}
return(list(
mean = mean(x),
median = median(x),
sd = sd(x),
min = min(x),
max = max(x),
range = max(x) - min(x)
))
}
summary_stats(c(1, 2, 3, 4, 5, NA))
permutation <- function(n, r) {
if (!is.numeric(n) || !is.numeric(r) ||
length(n) != 1 || length(r) != 1 ||
is.na(n) || is.na(r) ||
n %% 1 != 0 || r %% 1 != 0 ||
n < 0 || r < 0 || r > n) {
return("n và r phải là số nguyên không âm, với r <= n")
}
return(factorial(n) / factorial(n - r))
}
permutation(5, 2)
permutation(5, -1)
