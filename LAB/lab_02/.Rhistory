# 1. Viết function tìm các số nguyên tố từ 1 đến n
# Input: n
# Output: vector các số nguyên tố
find_primes <- function(n) {
if (!is.numeric(n) || length(n) != 1 || is.na(n) || n %% 1 != 0 || n > 2){
return("Input phải là số nguyên >= 2")
}
is_prime <- function(x) {
if (x < 2) return(FALSE)
for (i in 2:floor(sqrt(x))) {
if (x %% i == 0) return(FALSE)
}
return(TRUE)
}
primes <- c()
for (i in 2:n) {
if (is_prime(i)) {
primes <- c(primes, i)
}
}
return(primes)
}
find_primes(20)
pascal_triangle <- function(n) {
if (!is.numeric(n) || length(n) != 1 || is.na(n) || n %% 1 != 0 || n <= 0) {
return("n phải là số nguyên dương")
}
result <- list()
for (i in 0:(n - 1)) {
row <- c()
for (j in 0:i) {
row <- c(row, combination(i, j))
}
result[[i + 1]] <- row
}
return(result)
}
pascal_triangle(5)
# 3. Viết function phân loại sinh viên dựa vào điểm
# Input: điểm số
# Output: xếp loại (Xuất sắc, Giỏi, Khá, TB, Yếu)
# Kèm theo GPA scale 4.0
classify_student <- function(score) {
if (!is.numeric(score) || length(score) != 1 || is.na(score) || score < 0 || score > 10) {
return("Điểm phải là số từ 0 đến 10")
}
if (score >= 9) {
rank <- "Xuất sắc"
gpa <- 4.0
} else if (score >= 8) {
rank <- "Giỏi"
gpa <- 3.5
} else if (score >= 6.5) {
rank <- "Khá"
gpa <- 3.0
} else if (score >= 5) {
rank <- "Trung bình"
gpa <- 2.0
} else {
rank <- "Yếu"
gpa <- 1.0
}
return(list(
score = score,
classification = rank,
GPA_4 = gpa
))
}
classify_student(8.7)
