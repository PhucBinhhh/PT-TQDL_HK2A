shift_left_from <- function(df, row_id, start_col) {
end_col <- ncol(df)
df[row_id, start_col:end_col] <- c(df[row_id, (start_col+1):end_col], NA)
df
}
shift_left_from <- function(df, row_id, start_col) {
end_col <- ncol(df)
df[row_id, start_col:end_col] <- c(df[row_id, (start_col+1):end_col], NA)
df
}
col_income <- which(names(clients) == "Income")
bad_rows <- which(is.na(suppressWarnings(as.numeric(clients$Income))))
for(i in bad_rows){
clients <- shift_left_from(clients, i, col_income)
}
View(clients)
