# 3. Viết function tính tổ hợp C(n, r)
# Công thức: C(n,r) = n! / (r! * (n-r)!)
combination <- function(n,r ) {
if (!is.numeric(n) || !is.numeric(r) ||
length(n) != 1 || length(r) != 1 ||
is.na(n) || is.na(r) ||
n %% 1 != 0 || r %% 1 != 0 ||
n < 0 || r < 0 || r > n) {
return("n và r phải là số nguyên không âm, với r <= n")
}
return(factorial(n) / (factorial(r) * factorial(n - r)))
}
